<Window x:Class="SBIM.ETABS.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        
        Title="NPL Rhino"
        ResizeMode="NoResize"
        ShowInTaskbar="True" 
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Width="450"
        Height="680">

    
    <Window.Resources>
        <ResourceDictionary Source="resources/WPF/Resource/Styles.xaml" />
    </Window.Resources>

    <StackPanel>

        <GroupBox Header="Initialize" Margin="10">
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                <StackPanel>
                    <DockPanel>
                        <TextBox Text="{Binding rhinoPath}" Width="280" Focusable="False"/>
                        <Button HorizontalAlignment="Left" Content="Get File" Width="80" Click="btnGetPath_Click" FontWeight="Bold"/>
                    </DockPanel>
              
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                            <Button Content="Connect ETABS" Width="160" Height="25" Click="Connect_Click"/>
                            <Button Content="Generate Model" Width="160" Height="25" Click="Draw_Click"/>
                            <Button Content="Update Model" Width="160" Height="25" Click="UpdateModel_Click"/>
                           
                            <TextBlock x:Name="StatusText" Margin="0,20,0,0" Text="Ready" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Button Content="Clean Sections" Width="160" Height="25" Click="CleanSections_Click"/>
                            <Button Content="Create Sections" Width="160" Height="25" Click="CreateSection_Click"/>
                            <Button Content="Select Slabs" Width="160" Height="25" Click="SelSlab_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </GroupBox>

        <TabControl>
            <TabItem Header="Sections">
                <StackPanel>
                    <GroupBox>
                        <Border  BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                                <ListBox ItemsSource="{Binding RhinoTypeItems}" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding RhinoTypeName}" Margin="5"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </Border>
                    </GroupBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="For Check">
                <StackPanel>
                    <GroupBox>
                        <StackPanel>
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                                    <ListBox ItemsSource="{Binding RhinoObjectItems}" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="5">
                                                    <TextBlock Text="{Binding ObjectID}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding LayerName}"/>
                                                    <TextBlock Text="{Binding ObjectType}"/>
                                                    <TextBlock Text="{Binding CurveStart}"/>
                                                    <TextBlock Text="{Binding CurveEnd}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>
        </TabControl>
    </StackPanel>
</Window>